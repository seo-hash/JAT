// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum MembershipRole {
  OWNER
  ADMIN
  RECRUITER
  MANAGER
  VIEWER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  ACCESS_DENIED
}

enum NoteType {
  NOTA
  VALUTAZIONE
  COLLOQUIO
  FEEDBACK
}

enum InterviewType {
  PHONE
  VIDEO
  IN_PERSON
  ASSESSMENT
}

enum InterviewOutcome {
  PENDING
  PASSED
  FAILED
  NO_SHOW
  RESCHEDULED
}

enum MembershipInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum EmployeeStatus {
  ACTIVE
  ONBOARDING
  OFFBOARDING
  INACTIVE
}

enum OnboardingTaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum ReviewCycleStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum AbsenceType {
  FERIE
  PERMESSO
  MALATTIA
  ALTRO
}

enum AbsenceStatus {
  REQUESTED
  APPROVED
  REJECTED
  CANCELLED
}

enum DocumentSignatureStatus {
  DRAFT
  SENT
  SIGNED
  DECLINED
  ERROR
}

model Organization {
  id              String             @id @default(uuid())
  name            String
  clerkOrganizationId String?        @unique
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  memberships     Membership[]
  candidates      Candidate[]
  jobs            Job[]
  auditLogs       AuditLog[]
  invites         MembershipInvite[]
  employees       Employee[]
  reviewCycles    ReviewCycle[]
  onboardingTasks OnboardingTask[]
  reviews         Review[]
  applications    Application[]
  domains         OrganizationDomain[]
  cronofyAccounts CronofyAccount[]
  absences        Absence[]
  attendanceEntries AttendanceEntry[]
  documents       Document[]
}

model Membership {
  id             String         @id @default(uuid())
  userId         String
  organizationId String
  role           MembershipRole @default(RECRUITER)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  entity         String
  entityId       String?
  action         AuditAction
  metadata       Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
}

model MembershipInvite {
  id              String                 @id @default(uuid())
  organizationId  String
  email           String
  role            MembershipRole         @default(RECRUITER)
  status          MembershipInviteStatus @default(PENDING)
  invitedByUserId String
  token           String                 @unique
  expiresAt       DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email, status])
  @@index([organizationId, status])
}

model Task {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  completed Boolean  @default(false)
}

model Candidate {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Dati Anagrafici
  firstName String
  lastName  String
  email     String
  phone     String?
  city      String
  province  String?

  // Profilo Professionale
  role           String // Mansione/Ruolo
  seniority      String // Junior, Mid, Senior
  education      String? // Titolo di Studio
  sector         String // Settore
  expectedSalary Int? // RAL

  // Competenze e Stato
  skills String? // Hard Skills (tag o parole chiave)
  status String // In cerca, Colloquiato, Inserito, Non idoneo
  source String? @default("Diretto") // LinkedIn, Indeed, Jooble, Career Page, etc.

  // Documentazione e Note
  cvUrl          String?
  notes          String?         @db.Text // Note Recruiter
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  candidateNotes CandidateNote[]
  interviews     Interview[]
  applications   Application[]

  @@unique([organizationId, email])
  @@index([organizationId, userId])
}

model Application {
  id             String   @id @default(uuid())
  organizationId String
  candidateId    String
  jobId          String
  status         String   @default("Nuovo") // Nuovo, Screening, Colloquio, Proposta, Assunto, Respinto
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  candidate    Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job          Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([candidateId, jobId])
  @@index([candidateId])
  @@index([jobId])
  @@index([organizationId])
}

model CandidateNote {
  id             String    @id @default(uuid())
  organizationId String
  candidateId    String
  authorId       String // userId di chi scrive
  authorName     String // nome visualizzabile
  type           NoteType  @default(NOTA)
  content        String    @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  candidate      Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, createdAt])
  @@index([organizationId, createdAt])
}

model Interview {
  id             String           @id @default(uuid())
  organizationId String
  candidateId    String
  jobId          String?
  recruiterId    String
  recruiterName  String
  type           InterviewType    @default(VIDEO)
  outcome        InterviewOutcome @default(PENDING)
  scheduledAt    DateTime
  duration       Int? // minuti
  location       String? // link meet o indirizzo fisico
  notes          String?          @db.Text
  cronofyCalendarId String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  candidate      Candidate        @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, scheduledAt])
  @@index([organizationId, scheduledAt])
  @@index([recruiterId, scheduledAt])
}

model Job {
  id                String        @id @default(uuid())
  userId            String
  organizationId    String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  title             String
  company           String
  location          String
  locationFormatted String? // formatted location for aggregators
  city              String?
  province          String?
  country           String?       @default("IT")
  postalCode        String?
  description       String        @db.Text
  requirements      String        @db.Text
  responsibilities  String?       @db.Text
  benefits          String?       @db.Text
  sector            String
  industry          String?
  mode              String // Full-time, Part-time, Freelance
  status            String        @default("Aperto")
  experienceLevel   String?
  educationLevel    String?
  remoteType        String?
  salary            Int?
  salaryMin         Int?
  salaryMax         Int?
  salaryCurrency    String?       @default("EUR")
  salaryInterval    String?
  salaryText        String?
  applicationUrl    String?
  externalSource    String?
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  category          String?
  isActive          Boolean       @default(true)
  postedAt          DateTime?     @default(now())
  expiresAt         DateTime?
  
  // Multiposting flags
  postToLinkedIn    Boolean       @default(false)
  postToIndeed      Boolean       @default(false)
  postToJooble      Boolean       @default(false)
  
  organization      Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  applications      Application[]

  @@index([organizationId, userId])
}

model Employee {
  id              String           @id @default(uuid())
  organizationId  String
  firstName       String
  lastName        String
  email           String
  roleTitle       String
  department      String?
  managerName     String?
  hiredAt         DateTime?
  status          EmployeeStatus   @default(ONBOARDING)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  onboardingTasks OnboardingTask[]
  reviews         Review[]
  absences        Absence[]
  attendanceEntries AttendanceEntry[]
  documents       Document[]

  @@unique([organizationId, email])
  @@index([organizationId, status])
}

model OnboardingTask {
  id             String               @id @default(uuid())
  organizationId String
  employeeId     String
  title          String
  dueDate        DateTime?
  status         OnboardingTaskStatus @default(TODO)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee       Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([employeeId, status])
}

model ReviewCycle {
  id             String            @id @default(uuid())
  organizationId String
  name           String
  startsAt       DateTime?
  endsAt         DateTime?
  status         ReviewCycleStatus @default(DRAFT)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reviews        Review[]

  @@index([organizationId, status])
}

model Review {
  id             String       @id @default(uuid())
  organizationId String
  employeeId     String
  reviewCycleId  String
  score          Int?
  summary        String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewCycle    ReviewCycle  @relation(fields: [reviewCycleId], references: [id], onDelete: Cascade)

  @@unique([employeeId, reviewCycleId])
  @@index([organizationId, reviewCycleId])
}

model Tour {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  city        String
  country     String
  title       String
  description String   @db.Text
  image       String?  @db.Text
  stops       Json

  @@unique([city, country])
}

model Token {
  userId String @id
  tokens Int    @default(1000)
}

model OrganizationDomain {
  id             String       @id @default(uuid())
  organizationId String
  domain         String       @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model CronofyAccount {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  cronofySub     String
  profileId      String?
  calendarId     String?
  accessTokenEnc String       @db.Text
  refreshTokenEnc String      @db.Text
  expiresAt      DateTime?
  channelId      String?
  tzid           String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([cronofySub])
  @@index([channelId])
}

model Absence {
  id             String        @id @default(uuid())
  organizationId String
  employeeId     String
  requestedByUserId String
  type           AbsenceType
  status         AbsenceStatus @default(REQUESTED)
  startDate      DateTime
  endDate        DateTime
  notes          String?       @db.Text
  cronofyCalendarId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee       Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([organizationId, startDate])
  @@index([employeeId, startDate])
}

model AttendanceEntry {
  id             String       @id @default(uuid())
  organizationId String
  employeeId     String
  date           DateTime
  minutesWorked  Int
  overtimeMinutes Int?
  notes          String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([organizationId, date])
}

model Document {
  id             String                  @id @default(uuid())
  organizationId String
  employeeId     String?
  title          String
  fileUrl        String
  signatureRequestId String?
  signatureStatus DocumentSignatureStatus @default(DRAFT)
  signedFileUrl  String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee       Employee?               @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([signatureRequestId])
}
